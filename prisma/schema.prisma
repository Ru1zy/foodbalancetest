// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String  @id @default(uuid())
  phone          String  @unique // Залишаємо обов'язковим (користувач введе його пізніше)
  name           String
  chatId         String? @unique
  email          String? @unique // Для Google Auth
  googleId       String? @unique // Для Google Auth
  avatarUrl      String?         // Для аватарки
  address        String?
  defaultPackage String?
  defaultCutlery String?
  notes          String?

  orders   Order[]
  balances UserBalance[]
}

model UserBalance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String   // e.g., 'Slim', 'Active', 'Sushka S'
  totalDays   Int
  usedDays    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, packageId])
}

model Menu {
  id         String  @id @default(uuid())
  dayOfWeek  Int
  packageType String
  photoUrl   String?
  dishes     Json
}

model Tariff {
  id              String  @id @default(uuid())
  name            String  @unique
  title           String
  kcal            String
  price           String
  basePrice       Int
  previewImageUrl String?
  imageUrl        String?
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  deliveryDate    DateTime
  deliveryAddress String?
  packageType     String
  items           Json
  status          String   @default("new")
  isPaid          Boolean  @default(false)
  cutlery         Int      @default(0)
  notes           String?
  price           Int?
  balanceDaysUsed Int      @default(0)
  deliveryTime    String?
  deliveryNote    String?
  paymentMethod   String   @default("balance")

  @@index([deliveryDate, status])
  @@index([userId])
}

/// Idempotency guard for checkout submissions. The client sends a stable key
/// per checkout session; the unique constraint makes a retried/duplicated
/// submit (network retry, double-click, function replay) a no-op instead of a
/// second set of orders + double balance deduction.
model CheckoutIdempotency {
  id        String   @id @default(uuid())
  key       String   @unique
  userId    String?
  orderIds  String[] @default([])
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Maps a calendar month (`MM.YYYY`, e.g. `03.2026`) to the Google Spreadsheet
/// that receives that month's real-time order export. Lets the admin roll the
/// export forward month-to-month by adding one row, with no code changes. A
/// missing row for an upcoming month is detected by the proactive cron alert
/// and never fails a customer checkout (orders fall back to a manual-entry
/// Telegram warning instead).
model SheetConfig {
  id            String   @id @default(uuid())
  monthKey      String   @unique // "MM.YYYY", e.g. "03.2026"
  spreadsheetId String
  label         String?  // optional human note, e.g. "Березень 2026"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuthToken {
  id        String   @id @default(uuid())
  token     String   @unique
  chatId    String
  userName  String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([token])
  @@index([expiresAt])
}

model MergeToken {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}
